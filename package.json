      "static/src/js/**/*.js",
      "static/src/js/**/*.jsx",
      "static/src/js/**/*.ts",
      "static/src/js/**/*.tsx"
    ],
    "excludeAfterRemap": true
  },
  "overrides": {
    "react-sanitized-html": {
      "sanitize-html": "$sanitize-html",
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-input-range": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "mock-knex": {
      "knex": "$knex"
    },
    "react-toast-notifications": {
